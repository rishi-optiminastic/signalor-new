# Normalize line endings to LF everywhere, on every platform.
#
# Without this, Git on Windows (core.autocrlf=true) checks files out with CRLF
# while Prettier expects LF — so a clean clone fails `pnpm lint` with thousands
# of "Delete `␍`" errors that CI (Linux) never sees. Contributors should not have
# to debug that on day one.
#
# After changing this file, refresh an existing clone with:
#   git add --renormalize . && git status
* text=auto eol=lf

# Windows-only scripts must keep CRLF to run.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets — never convert, never diff as text.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.avif binary
*.svg text
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.pdf binary
*.mp4 binary
*.webm binary
*.zip binary

# Lockfile: generated. Keep it out of diffs and collapse it in reviews.
pnpm-lock.yaml -diff linguist-generated=true
