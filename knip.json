{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    "app/**/{page,layout,template,error,loading,not-found,route}.{ts,tsx}",
    "middleware.ts",
    "next.config.{js,mjs,ts}",
    "prisma/schema.prisma"
  ],
  "project": ["**/*.{ts,tsx}!"],
  "ignore": [
    "components/ui/**",
    ".next/**",
    "node_modules/**"
  ],
  "ignoreDependencies": [
    "tailwindcss",
    "tw-animate-css",
    "autoprefixer",
    "postcss",
    "@tailwindcss/postcss"
  ]
}
