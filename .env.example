# ─────────────────────────────────────────────────────────────────────────────
# Signalor web — environment
#
# Copy to `.env.local` and fill in. NEVER commit a real .env file (.gitignore
# already blocks `.env*`).
#
# Fastest path to a running app — no database, no backend, no API keys:
#
#   NEXT_PUBLIC_USE_STUBS=true
#   SKIP_ENV_VALIDATION=1
#   pnpm dev
#
# Everything below is only needed once you want real data/auth/billing.
# Validation lives in `lib/env.ts` + `features/site/lib/env.ts` (t3-oss/env-nextjs).
# ─────────────────────────────────────────────────────────────────────────────


# ── Required (server) ────────────────────────────────────────────────────────

# Postgres connection string. This app talks to Postgres directly (better-auth
# stores users/sessions here), so a real DB is needed unless you use stubs.
DATABASE_URL=postgresql://user:password@localhost:5432/signalor

# better-auth signing secret. Generate one: `openssl rand -base64 32`
BETTER_AUTH_SECRET=

# Where better-auth is served from — the app's own origin in development.
BETTER_AUTH_URL=http://localhost:3000


# ── Required (client) ────────────────────────────────────────────────────────

# This app's public origin.
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ── Backend API ──────────────────────────────────────────────────────────────

# The Signalor analyzer backend (Django). It is a separate, proprietary service
# and is NOT part of this repository — see the README. Leave the default and set
# NEXT_PUBLIC_USE_STUBS=true to run the UI without it.
NEXT_PUBLIC_API_URL=http://localhost:8000

# 'true' makes onboarding/analysis return mocked data instead of calling the
# backend or sending OTP emails. This is the supported way to run the whole UI
# with no infrastructure.
NEXT_PUBLIC_USE_STUBS=false


# ── Auth: Google OAuth (optional) ────────────────────────────────────────────
# Google sign-in is enabled only when BOTH are set. Email OTP works without them.

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# ── Email (optional) ─────────────────────────────────────────────────────────
# Defaults to 'console', which logs emails instead of pretending to send them.
# Set to 'resend' or 'sendgrid' and supply the matching key to send for real.

EMAIL_PROVIDER=console
RESEND_API_KEY=
SENDGRID_API_KEY=
FROM_EMAIL=

# ── Marketing site (optional) ────────────────────────────────────────────────

NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Sanity CMS — powers the blog. Both must be set for blog routes to fetch;
# without them the blog degrades instead of crashing.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=
NEXT_PUBLIC_SANITY_API_VERSION=2026-05-02

# Cloudflare Turnstile (bot check on public forms). Site key is public by design.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Framer plugin dev server — only used when working on the Framer plugin.
NEXT_PUBLIC_FRAMER_PLUGIN_URL=https://localhost:5176/


# ── Analytics (optional) ─────────────────────────────────────────────────────
# Leave blank to disable. No analytics are sent when unset.

NEXT_PUBLIC_AMPLITUDE_API_KEY=
NEXT_PUBLIC_CLARITY_PROJECT_ID=


# ── Billing: Dodo Payments (optional) ────────────────────────────────────────
# Only needed for the checkout route (app/api/dodo/checkout).

DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_PRODUCT_ID=
DODO_PAYMENTS_API_BASE=


# ── Escape hatch ─────────────────────────────────────────────────────────────
# Set to 1 to bypass env schema validation (useful for stub-only runs and CI
# builds that never touch a real service).
SKIP_ENV_VALIDATION=
